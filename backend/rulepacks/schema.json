{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://leai.example/rulepacks/schema.json",
  "title": "LEAI Framework Rulepack",
  "description": "Schema for framework reference data rulepacks. Field names per ScoringEngineReqs.md section 10.1; clause_ref format per section 6.2.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "version", "issuing_body", "geography_tags", "clauses"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "issuing_body": {
      "type": "string",
      "minLength": 1
    },
    "geography_tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "clauses": {
      "type": "array",
      "minItems": 12,
      "maxItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["clause_ref", "text_summary", "category_tag", "risk_weight"],
        "properties": {
          "clause_ref": {
            "type": "string",
            "minLength": 1,
            "description": "Fully qualified clause identifier: framework name, version, and clause number (ScoringEngineReqs.md section 6.2)."
          },
          "text_summary": {
            "type": "string",
            "minLength": 1
          },
          "category_tag": {
            "type": "string",
            "minLength": 1
          },
          "risk_weight": {
            "type": "number",
            "minimum": 1,
            "maximum": 3
          }
        }
      }
    }
  }
}
